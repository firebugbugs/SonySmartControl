<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 主窗口内面板按钮：与 Fluent 标题栏/侧栏协调 -->
    <Style Selector="Button.sidebar-icon-tool">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="MinWidth" Value="28"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="0.72"/>
    </Style>
    <Style Selector="Button.sidebar-icon-tool:pointerover">
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.filmstrip-tile">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="ClickMode" Value="Release"/>
    </Style>
    <Style Selector="Button.filmstrip-tile:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <!-- 胶片条左侧「实时」按钮：自适应高度 + 卡片风格 -->
    <Style Selector="Button.filmstrip-live-tile">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Card"
                        CornerRadius="10"
                        Background="#F2F4F8"
                        BorderBrush="#E1E6EF"
                        BorderThickness="1">
                    <ContentPresenter x:Name="PART_ContentPresenter"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="12,10"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.filmstrip-live-tile:pointerover /template/ Border#Card">
        <Setter Property="Background" Value="#EAF2FF"/>
        <Setter Property="BorderBrush" Value="#C9DDFF"/>
    </Style>
    <Style Selector="Button.filmstrip-live-tile:pressed /template/ Border#Card">
        <Setter Property="Background" Value="#DDEBFF"/>
        <Setter Property="BorderBrush" Value="#B7D1FF"/>
    </Style>
    <Style Selector="Button.popup-lite">
        <Setter Property="Background" Value="#F5F7FA"/>
        <Setter Property="BorderBrush" Value="#D6DCE5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Foreground" Value="#1F2430"/>
    </Style>
    <Style Selector="Button.popup-lite:pointerover">
        <Setter Property="Background" Value="#EDF1F6"/>
    </Style>
    <Style Selector="Button.popup-danger">
        <Setter Property="Background" Value="#FFEDEE"/>
        <Setter Property="BorderBrush" Value="#F1C4C7"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Foreground" Value="#A1262D"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.popup-danger:pointerover">
        <Setter Property="Background" Value="#FFE3E5"/>
    </Style>

    <Style Selector="Border.sidebar-mode-switch">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#4286F5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="3"/>
    </Style>

    <Style Selector="Border.sidebar-mode-thumb">
        <Setter Property="Background" Value="#4286F5"/>
        <Setter Property="BorderBrush" Value="#4286F5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="11"/>
    </Style>

    <Style Selector="Button.sidebar-mode-option">
        <Setter Property="Background" Value="#01000000"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#4286F5"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Margin="{TemplateBinding Padding}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.sidebar-mode-option:pointerover">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Background" Value="#01000000"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.sidebar-mode-option:pressed">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Background" Value="#01000000"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
</Styles>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:SonySmartControl.Controls"
             xmlns:models="using:SonySmartControl.Models"
             x:Class="SonySmartControl.Controls.FilmstripPhotoInfoTip"
             x:DataType="models:RecentPhotoEntry"
             MinWidth="300"
             MaxWidth="400">
    <Border Padding="12,10"
            CornerRadius="8"
            Background="#1E2229"
            BorderBrush="#3D4455"
            BorderThickness="1">
        <StackPanel Spacing="8">
            <TextBlock Text="{Binding FileLabel}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="#E8ECF2"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding MetaLinePixel}"
                       FontFamily="Consolas,Cascadia Mono,monospace"
                       FontSize="11"
                       Foreground="#B8C0CC"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="{Binding MetaLineFile}"
                           FontSize="10"
                           Foreground="#8A93A3"
                           TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding MetaLineTime}"
                           FontSize="10"
                           Foreground="#8A93A3"
                           VerticalAlignment="Top"
                           TextAlignment="Right"/>
            </Grid>
            <Border Padding="8,8"
                    CornerRadius="6"
                    Background="#181C24"
                    BorderBrush="#2E3540"
                    BorderThickness="1">
                <Grid ColumnDefinitions="52,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="5"
                      ColumnSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="相机" FontSize="10" Foreground="#6B7380" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MetaExifCamera}" FontSize="10" Foreground="#C5CDD8" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="镜头" FontSize="10" Foreground="#6B7380" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MetaExifLens}" FontSize="10" Foreground="#C5CDD8" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ISO" FontSize="10" Foreground="#6B7380"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MetaExifIso}" FontSize="10" Foreground="#C5CDD8" FontFamily="Consolas,Cascadia Mono,monospace"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="光圈" FontSize="10" Foreground="#6B7380"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MetaExifAperture}" FontSize="10" Foreground="#C5CDD8" FontFamily="Consolas,Cascadia Mono,monospace"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="快门" FontSize="10" Foreground="#6B7380"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MetaExifShutter}" FontSize="10" Foreground="#C5CDD8" FontFamily="Consolas,Cascadia Mono,monospace"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="补偿" FontSize="10" Foreground="#6B7380"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MetaExifEv}" FontSize="10" Foreground="#C5CDD8" FontFamily="Consolas,Cascadia Mono,monospace"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="焦距" FontSize="10" Foreground="#6B7380"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding MetaExifFocal}" FontSize="10" Foreground="#C5CDD8" FontFamily="Consolas,Cascadia Mono,monospace"/>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="拍摄" FontSize="10" Foreground="#6B7380" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding MetaExifCaptureTime}" FontSize="10" Foreground="#C5CDD8" FontFamily="Consolas,Cascadia Mono,monospace" TextWrapping="Wrap"/>
                </Grid>
            </Border>
            <StackPanel Spacing="4">
                <TextBlock Text="亮度直方图 · 源图像 · Luminance (Rec.709 系数)"
                           FontSize="10"
                           Foreground="#6B7380"/>
                <Border Height="56"
                        CornerRadius="4"
                        Background="#14171C"
                        BorderBrush="#2A3038"
                        BorderThickness="1"
                        Padding="6,4">
                    <controls:HistogramMiniControl Bins="{Binding TooltipHistogramBins}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

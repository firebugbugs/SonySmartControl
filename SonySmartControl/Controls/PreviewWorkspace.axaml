<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SonySmartControl.ViewModels"
             xmlns:controls="using:SonySmartControl.Controls"
             xmlns:behaviors="using:SonySmartControl.Behaviors"
             x:Class="SonySmartControl.Controls.PreviewWorkspace"
             x:DataType="vm:MainWindowViewModel">
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="4*" MinHeight="220"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto" MinHeight="110" MaxHeight="180"/>
        </Grid.RowDefinitions>

        <Border x:Name="PreviewBorder"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="#D0D5DE" BorderThickness="1" CornerRadius="12" ClipToBounds="True"
                behaviors:PreviewLayoutSyncBehavior.IsLayoutSyncEnabled="True">
            <Grid>
                <Border Background="Transparent"
                        ClipToBounds="True"
                        IsVisible="{Binding IsLivePreviewVisible}"
                        behaviors:PreviewFocusGestureBehavior.IsPreviewGestureEnabled="True"
                                behaviors:PreviewRelativeFocusWheelBehavior.IsRelativeFocusWheelEnabled="True"
                        Cursor="Hand"
                        ToolTip.Tip="在预览上按下并按住：选对焦点并半按对焦；松开以释放。机身对焦框右上角可取消遥控触摸区域。">
                    <Grid Background="Transparent" ClipToBounds="True">
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" IsHitTestVisible="False"/>
                        <controls:CompositionGuideOverlay ModeIndex="{Binding GuideOverlayIndex}"
                                                          SourceImage="{Binding PreviewImage}"
                                                          IsVisible="{Binding IsGuideOverlayVisible}"/>
                        <controls:LuminanceHistogramOverlay SourceImage="{Binding PreviewImage}"
                                                            Bins="{Binding LuminanceHistogramBins}"
                                                            IsVisible="{Binding IsHistogramOverlayVisible}"/>
                        <controls:AfFocusFramesOverlay SourceImage="{Binding PreviewImage}"
                                                       Frames="{Binding SdkAfFocusFrames}"
                                                       IsVisible="{Binding IsSdkAfFramesOverlayVisible}"/>
                        <Button HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="{Binding FocusReticleCloseMargin}"
                                Width="22" Height="22"
                                Padding="0"
                                Background="#DC202020"
                                BorderThickness="0"
                                CornerRadius="11"
                                Cursor="Hand"
                                IsVisible="{Binding IsFocusReticleCloseButtonVisible}"
                                Command="{Binding DismissPreviewTouchFocusCommand}"
                                ToolTip.Tip="取消触摸对焦点，机身恢复自动对焦区域">
                            <TextBlock Text="×"
                                       FontSize="15"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>
                <controls:PhotoPanZoomViewer IsVisible="{Binding IsStaticReviewVisible}"
                                             Source="{Binding StaticReviewImage}"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="1"
                      Height="6"
                      Margin="16,0,16,0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Cursor="SizeNorthSouth"
                      Background="#01000000"
                      BorderThickness="0"/>

        <Border x:Name="RecentFilmstripBar"
                Grid.Row="2"
                CornerRadius="12"
                Background="#FFFFFF"
                BorderBrush="#D9DEE8"
                BorderThickness="1"
                Padding="12,10"
                ClipToBounds="True"
                BoxShadow="0 2 8 0 #12000000"
                behaviors:FilmstripBarWheelBehavior.IsFilmstripWheelEnabled="True">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Width="126"
                        MinHeight="52"
                        CornerRadius="10"
                        ClipToBounds="True"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <!-- 选中态背景：放在按钮背后 -->
                        <Border IsVisible="{Binding IsViewingLiveMonitor}"
                                Background="#D4E8FC"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                        <Button Classes="filmstrip-live-tile"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Command="{Binding ShowLiveMonitorCommand}"
                                ToolTip.Tip="返回实时取景">
                            <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="6">
                                <TextBlock Text="&#xE6F6;"
                                           FontFamily="avares://SonySmartControl/Assets/Fonts/iconfont.ttf#CheemsFont"
                                           FontSize="18"
                                           Foreground="#1F5FAF"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="实时"
                                           FontWeight="SemiBold"
                                           Foreground="#1E3A5F"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <controls:FilmstripPhotosHost x:Name="FilmstripPhotos"
                                              Grid.Column="1"
                                              behaviors:FilmstripHostWidthSyncBehavior.IsWidthSyncEnabled="True"
                                              ItemsSource="{Binding RecentPhotos}"
                                              SelectCommand="{Binding ShowRecentPhotoCommand}"
                                              DeleteCommand="{Binding DeletePreviewImageCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SonySmartControl.ViewModels"
        xmlns:controls="using:SonySmartControl.Controls"
        xmlns:interop="using:SonySmartControl.Interop"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="760"
        x:Class="SonySmartControl.Views.MainWindow"
        x:Name="Win"
        x:DataType="vm:MainWindowViewModel"
        Title="索尼实时视窗"
        Icon="avares://SonySmartControl/Assets/cheems.ico"
        Width="1200" Height="760"
        MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        CanResize="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="False"
        Loaded="MainWindow_OnLoaded"
        KeyDown="MainWindow_OnKeyDown">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.sidebar-icon-tool">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.72"/>
        </Style>
        <Style Selector="Button.sidebar-icon-tool:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.filmstrip-tile">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Release"/>
        </Style>
        <Style Selector="Button.filmstrip-tile:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.92"/>
        </Style>
    </Window.Styles>

    <!-- 边缘 6px 命中区 + 中心卡片；最大化时边缘改为 0，避免透明缝露出桌面 -->
    <Grid x:Name="OuterChromeGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="ResizeNw" Grid.Row="0" Grid.Column="0"
                Background="Transparent" Cursor="TopLeftCorner" PointerPressed="ResizeNw_OnPointerPressed"/>
        <Border x:Name="ResizeN" Grid.Row="0" Grid.Column="1"
                Background="Transparent" Cursor="SizeNorthSouth" PointerPressed="ResizeN_OnPointerPressed"/>
        <Border x:Name="ResizeNe" Grid.Row="0" Grid.Column="2"
                Background="Transparent" Cursor="TopRightCorner" PointerPressed="ResizeNe_OnPointerPressed"/>

        <Border x:Name="ResizeW" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2"
                Background="Transparent" Cursor="SizeWestEast" PointerPressed="ResizeW_OnPointerPressed"/>
        <Border x:Name="ResizeE" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                Background="Transparent" Cursor="SizeWestEast" PointerPressed="ResizeE_OnPointerPressed"/>

        <Border x:Name="ResizeSw" Grid.Row="3" Grid.Column="0"
                Background="Transparent" Cursor="BottomLeftCorner" PointerPressed="ResizeSw_OnPointerPressed"/>
        <Border x:Name="ResizeS" Grid.Row="3" Grid.Column="1"
                Background="Transparent" Cursor="SizeNorthSouth" PointerPressed="ResizeS_OnPointerPressed"/>
        <Border x:Name="ResizeSe" Grid.Row="3" Grid.Column="2"
                Background="Transparent" Cursor="BottomRightCorner" PointerPressed="ResizeSe_OnPointerPressed"/>

        <Border x:Name="CardRoot"
                Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                CornerRadius="14"
                ClipToBounds="True"
                Background="#F6F7FA"
                BorderBrush="#D9DEE8"
                BorderThickness="1"
                BoxShadow="0 12 40 0 #28000000">
            <Grid RowDefinitions="Auto,Auto,*">
                <!-- 标题栏：拖拽移动；图标与「页面标题」同排；作者信息仅悬停页面标题时显示 -->
                <Border x:Name="TitleBarHost"
                        Grid.Row="0"
                        MinHeight="44"
                        Background="#EEF0F5"
                        BorderBrush="#D9DEE8"
                        BorderThickness="0,0,0,1"
                        Padding="12,0,4,0"
                        PointerPressed="TitleBar_OnPointerPressed">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <Image Grid.Column="0"
                               Width="22" Height="22"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Source="avares://SonySmartControl/Assets/cheems.ico"
                               IsHitTestVisible="False"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                            <TextBlock x:Name="AppTitleText"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2430"
                                       Text="索尼实时视窗"
                                       Cursor="Help"
                                       IsHitTestVisible="True">
                                <ToolTip.Tip>
                                    <StackPanel MinWidth="200" Spacing="4">
                                        <TextBlock Text="作者：萤灬虫"/>
                                        <TextBlock Text="B站ID：43096314"/>
                                    </StackPanel>
                                </ToolTip.Tip>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <Button x:Name="ChromeMinimize"
                                    Classes="chrome-caption-btn"
                                    Click="ChromeMinimize_OnClick"
                                    ToolTip.Tip="最小化">
                                <Path Width="10" Height="1" Stretch="None"
                                      Stroke="#5C6370" StrokeThickness="1.25"
                                      Data="M 0 0 L 10 0"/>
                            </Button>
                            <Button x:Name="ChromeMaximize"
                                    Classes="chrome-caption-btn"
                                    Click="ChromeMaximize_OnClick"
                                    ToolTip.Tip="最大化">
                                <Panel>
                                    <Path x:Name="MaximizeGlyph"
                                          Width="12" Height="12" Stretch="Uniform"
                                          Stroke="#5C6370" StrokeThickness="1.15"
                                          Fill="Transparent"
                                          Data="M 2 2 L 10 2 L 10 10 L 2 10 Z"/>
                                    <Path x:Name="RestoreGlyph"
                                          IsVisible="False"
                                          Width="12" Height="12" Stretch="Uniform"
                                          Stroke="#5C6370" StrokeThickness="1.1"
                                          Fill="Transparent"
                                          Data="M 4 2 L 10 2 L 10 7 L 4 7 Z M 2 5 L 8 5 L 8 10 L 2 10 Z"/>
                                </Panel>
                            </Button>
                            <Button x:Name="ChromeClose"
                                    Classes="chrome-caption-close"
                                    Click="ChromeClose_OnClick"
                                    ToolTip.Tip="关闭">
                                <TextBlock Text="✕"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 工具行：连接 / 状态（不再与整行标题共享 Tooltip 命中区） -->
                <Border Grid.Row="1" Padding="16,12,16,0" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="chrome-text"
                                Content="连接"
                                Command="{Binding ConnectCommand}"
                                IsEnabled="{Binding IsConnectEnabled}"/>
                        <Button Classes="chrome-text"
                                Content="断开"
                                Command="{Binding DisconnectCommand}"
                                IsEnabled="{Binding IsDisconnectEnabled}"/>
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#4B5260"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="16" ColumnDefinitions="*,280" ColumnSpacing="12">
                        <Grid Grid.Column="0" RowDefinitions="*,Auto" RowSpacing="8">
                            <!-- 预览框与底部胶片条分离：预览仅含实时画面与叠加层 -->
                                <Border x:Name="PreviewBorder"
                                        Grid.Row="0"
                                        Background="Transparent"
                                        BorderBrush="#D0D5DE" BorderThickness="1" CornerRadius="12" ClipToBounds="True"
                                        SizeChanged="PreviewBorder_OnSizeChanged">
                                    <Grid>
                                        <Border Background="Transparent"
                                                ClipToBounds="True"
                                                IsVisible="{Binding IsLivePreviewVisible}"
                                                PointerPressed="PreviewBorder_OnPointerPressed"
                                                PointerReleased="PreviewBorder_OnPointerReleased"
                                                PointerCaptureLost="PreviewBorder_OnPointerCaptureLost"
                                                Cursor="Hand"
                                                ToolTip.Tip="在预览上按下并按住：选对焦点并半按对焦；松开以释放。机身对焦框右上角可取消遥控触摸区域。">
                                            <Grid Background="Transparent" ClipToBounds="True">
                                                <Image Source="{Binding PreviewImage}" Stretch="Uniform" IsHitTestVisible="False"/>
                                                <controls:CompositionGuideOverlay ModeIndex="{Binding GuideOverlayIndex}"
                                                                                  SourceImage="{Binding PreviewImage}"
                                                                                  IsVisible="{Binding IsGuideOverlayVisible}"/>
                                                <controls:LuminanceHistogramOverlay SourceImage="{Binding PreviewImage}"
                                                                                    Bins="{Binding LuminanceHistogramBins}"
                                                                                    IsVisible="{Binding IsHistogramOverlayVisible}"/>
                                                <controls:AfFocusFramesOverlay SourceImage="{Binding PreviewImage}"
                                                                               Frames="{Binding SdkAfFocusFrames}"
                                                                               IsVisible="{Binding IsSdkAfFramesOverlayVisible}"/>
                                                <Button HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="{Binding FocusReticleCloseMargin}"
                                                        Width="22" Height="22"
                                                        Padding="0"
                                                        Background="#DC202020"
                                                        BorderThickness="0"
                                                        CornerRadius="11"
                                                        Cursor="Hand"
                                                        IsVisible="{Binding IsFocusReticleCloseButtonVisible}"
                                                        Command="{Binding DismissPreviewTouchFocusCommand}"
                                                        ToolTip.Tip="取消触摸对焦点，机身恢复自动对焦区域">
                                                    <TextBlock Text="×"
                                                               FontSize="15"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <controls:PhotoPanZoomViewer IsVisible="{Binding IsStaticReviewVisible}"
                                                                     Source="{Binding StaticReviewImage}"/>
                                    </Grid>
                                </Border>

                                <Border x:Name="RecentFilmstripBar"
                                        Grid.Row="1"
                                        CornerRadius="12"
                                        Background="#FFFFFF"
                                        BorderBrush="#D9DEE8"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        ClipToBounds="True"
                                        BoxShadow="0 2 8 0 #12000000">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0"
                                                    Width="126"
                                                    VerticalAlignment="Center">
                                            <Panel Height="96">
                                                <Border CornerRadius="8"
                                                        Background="#EEF1F6"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"/>
                                                <Border CornerRadius="8"
                                                        IsVisible="{Binding IsViewingLiveMonitor}"
                                                        Background="#D4E8FC"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"/>
                                                <Button Classes="filmstrip-tile"
                                                        Height="96"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Focusable="False"
                                                        Command="{Binding ShowLiveMonitorCommand}"
                                                        ToolTip.Tip="返回实时取景">
                                                    <TextBlock Text="实时"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1E3A5F"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </Panel>
                                        </StackPanel>

                                        <controls:FilmstripPhotosHost x:Name="FilmstripPhotos"
                                                                      Grid.Column="1"
                                                                      SizeChanged="FilmstripPhotos_OnSizeChanged"
                                                                      ItemsSource="{Binding RecentPhotos}"
                                                                      SelectCommand="{Binding ShowRecentPhotoCommand}"/>
                                    </Grid>
                                </Border>
                        </Grid>

                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="10">
                                <StackPanel Grid.Row="0" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="#1F2430" Text="遥控拍摄"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <Button Grid.Column="0"
                                                x:Name="FocusHoldButton"
                                                Classes="camera-focus"
                                                Content="对焦"
                                                IsEnabled="{Binding ShutterActionButtonsEnabled}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                ToolTip.Tip="可选：与在预览上按住相同（半按对焦，松开释放）。未在预览选点时则为普通半按。"/>
                                        <Button Grid.Column="1"
                                                x:Name="CaptureHoldButton"
                                                Classes="camera-capture"
                                                Content="拍照"
                                                IsEnabled="{Binding ShutterActionButtonsEnabled}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                ToolTip.Tip="单张/延时：按住半按对焦，松开释放快门一次。连拍模式：按住后半按对焦再全按连拍，保持按住可持续连拍，松手停止。保存路径与格式在侧栏「保存设置」中修改后立即生效。"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
                                    <Button Classes="sidebar-icon-tool"
                                            Command="{Binding ExpandAllSectionsCommand}"
                                            ToolTip.Tip="全部展开">
                                        <Path Width="18" Height="18" Stretch="Uniform"
                                              Stroke="#666666" StrokeThickness="1.65"
                                              Data="M 2 3 L 10 11 L 18 3 M 2 9 L 10 17 L 18 9"/>
                                    </Button>
                                    <Button Classes="sidebar-icon-tool"
                                            Command="{Binding CollapseAllSectionsCommand}"
                                            ToolTip.Tip="全部收起">
                                        <Path Width="18" Height="18" Stretch="Uniform"
                                              Stroke="#666666" StrokeThickness="1.65"
                                              Data="M 2 15 L 10 7 L 18 15 M 2 9 L 10 1 L 18 9"/>
                                    </Button>
                                </StackPanel>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" ClipToBounds="False">
                                    <StackPanel Spacing="10">
                                        <Expander IsExpanded="{Binding SaveSectionExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch">
                                            <Expander.Header>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="保存设置"
                                                           VerticalAlignment="Center"/>
                                            </Expander.Header>
                                            <StackPanel Spacing="10" Margin="0,4,0,0">
                                                <TextBlock Text="保存目录"/>
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                                    <TextBox Grid.Column="0" Text="{Binding SaveDirectory}" Watermark="文件夹路径"/>
                                                    <Button Grid.Column="1"
                                                            Classes="chrome-text"
                                                            Content="浏览…"
                                                            Command="{Binding BrowseSaveFolderCommand}"
                                                            Padding="12,6"/>
                                                    <Button Grid.Column="2"
                                                            Classes="chrome-text"
                                                            Content="打开"
                                                            Command="{Binding OpenSaveFolderCommand}"
                                                            Padding="12,6"
                                                            ToolTip.Tip="在文件资源管理器中打开此文件夹"/>
                                                </Grid>

                                                <TextBlock Text="文件名前缀"/>
                                                <TextBox Text="{Binding FileNamePrefix}" Watermark="例如 DSC"/>

                                                <TextBlock Text="保存格式"/>
                                                <ComboBox SelectedIndex="{Binding CaptureFormatIndex}">
                                                    <ComboBoxItem Content="JPEG"/>
                                                    <ComboBoxItem Content="RAW"/>
                                                    <ComboBoxItem Content="RAW + JPEG"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Expander>

                                        <Border IsVisible="{Binding ShootingPanelVisible}"
                                                Opacity="{Binding ShootingPanelOpacity}"
                                                Padding="0,4,0,0">
                                            <StackPanel Spacing="10">
                                                <Expander IsExpanded="{Binding GeneralSectionExpanded, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch">
                                                    <Expander.Header>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="通用设置"
                                                                   VerticalAlignment="Center"/>
                                                    </Expander.Header>
                                                    <StackPanel Spacing="8" Margin="0,4,0,0">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <TextBlock Grid.Column="0"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       Text="屏幕开关"
                                                                       ToolTip.Tip="关闭后机身背屏熄灭；开启后恢复显示。"/>
                                                            <ToggleSwitch Grid.Column="1"
                                                                          VerticalAlignment="Center"
                                                                          OnContent="开"
                                                                          OffContent="关"
                                                                          IsChecked="{Binding CameraScreenPowerOn, Mode=TwoWay}"
                                                                          IsEnabled="{Binding CameraScreenPowerEnabled}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander IsExpanded="{Binding ExposureSectionExpanded, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch">
                                                    <Expander.Header>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="拍照设置"
                                                                   VerticalAlignment="Center"/>
                                                    </Expander.Header>
                                                    <StackPanel Spacing="8" Margin="0,4,0,0">
                                                        <TextBlock Text="对焦模式"
                                                                   ToolTip.Tip="若下拉为灰色：机身须允许从电脑改写（Writable）；AF/MF 开关在镜头或菜单上、部分模式会锁定对焦。"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding FocusModeChoices}"
                                                                                   SelectedIndex="{Binding SelectedFocusModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding FocusModeEnabled}"/>

                                                        <TextBlock Text="拍摄方式"
                                                                   ToolTip.Tip="单张 / 连拍 / 延时自拍，对应机身驱动模式（CrDeviceProperty_DriveMode）。连拍与延时下可选具体速度或秒数。"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding DriveModeCategoryLabels}"
                                                                  SelectedIndex="{Binding SelectedDriveCategoryIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding DriveModeCategoryEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged"/>
                                                        <TextBlock Text="{Binding DriveModeSubLabel}"
                                                                   IsVisible="{Binding DriveModeSubRowVisible}"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding DriveModeSubChoices}"
                                                                  SelectedIndex="{Binding SelectedDriveSubIndex, Mode=TwoWay}"
                                                                  IsVisible="{Binding DriveModeSubRowVisible}"
                                                                  IsEnabled="{Binding DriveModeCategoryEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <TextBlock Text="{Binding DriveModeOtherHint}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="11"
                                                                   Opacity="0.85"
                                                                   Foreground="#666666"
                                                                   IsVisible="{Binding HasDriveModeOtherHint}"/>

                                                        <TextBlock Text="曝光模式（P/A/S/M 等）"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding ExposureModeChoices}"
                                                                                   SelectedIndex="{Binding SelectedExposureModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding ExposureModeEnabled}"/>

                                                        <TextBlock Text="光圈"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding ApertureChoices}"
                                                                                   SelectedIndex="{Binding SelectedApertureIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding ApertureEnabled}"
                                                                                   WheelAdjustEnabled="True"/>

                                                        <TextBlock Text="快门类型"
                                                                   ToolTip.Tip="自动 / 机械快门 / 电子快门（CrDeviceProperty_ShutterType）。不支持或不可调时机身为灰色。"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding ShutterTypeChoices}"
                                                                  SelectedIndex="{Binding SelectedShutterTypeIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding ShutterTypeEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBlock Text="快门速度"/>
                                                        <ComboBox x:Name="ShutterSpeedCombo"
                                                                  MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding ShutterChoices}"
                                                                  SelectedIndex="{Binding SelectedShutterIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding ShutterEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBlock Text="ISO"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding IsoChoices}"
                                                                                   SelectedIndex="{Binding SelectedIsoIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding IsoEnabled}"
                                                                                   WheelAdjustEnabled="True"/>

                                                        <TextBlock Text="曝光补偿"
                                                                   ToolTip.Tip="与机身曝光补偿（±EV）一致；数值为 SDK 的「EV×1000」。下拉选择；或在本框悬停约 0.25s 后用滚轮微调（与光圈/快门/ISO 相同）。"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding ExposureBiasChoices}"
                                                                                   SelectedIndex="{Binding SelectedExposureBiasIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding ExposureBiasEnabled}"
                                                                                   InvertWheel="True"
                                                                                   WheelAdjustEnabled="True"/>
                                                        <TextBlock Text="{Binding ExposureCompensationHint}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="11"
                                                                   Opacity="0.85"
                                                                   Foreground="#B06020"
                                                                   IsVisible="{Binding HasExposureCompensationHint}"/>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </Border>

                                        <Expander IsExpanded="{Binding AuxDisplaySectionExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch">
                                            <Expander.Header>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="辅助显示"
                                                           VerticalAlignment="Center"/>
                                            </Expander.Header>
                                            <StackPanel Spacing="8" Margin="0,4,0,0">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Text="直方图"
                                                               ToolTip.Tip="关闭后不显示右上角亮度直方图。"/>
                                                    <ToggleSwitch Grid.Column="1"
                                                                  VerticalAlignment="Center"
                                                                  OnContent="开"
                                                                  OffContent="关"
                                                                  IsChecked="{Binding ShowHistogram, Mode=TwoWay}"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Text="辅助线"
                                                               ToolTip.Tip="在预览画面有效区域内叠加构图参考线。"/>
                                                    <controls:WheelPickerCombo Grid.Column="1"
                                                                               MinWidth="168"
                                                                               ItemsSource="{Binding GuideOverlayChoices}"
                                                                               SelectedIndex="{Binding GuideOverlayIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

</Window>

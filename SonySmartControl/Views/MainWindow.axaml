<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SonySmartControl.ViewModels"
        xmlns:controls="using:SonySmartControl.Controls"
        xmlns:interop="using:SonySmartControl.Interop"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="760"
        x:Class="SonySmartControl.Views.MainWindow"
        x:Name="Win"
        x:DataType="vm:MainWindowViewModel"
        Title="索尼实时视窗"
        Icon="avares://SonySmartControl/Assets/cheems.ico"
        Width="1200" Height="760"
        MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        CanResize="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="False"
        Loaded="MainWindow_OnLoaded"
        KeyDown="MainWindow_OnKeyDown">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.sidebar-icon-tool">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.72"/>
        </Style>
        <Style Selector="Button.sidebar-icon-tool:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.filmstrip-tile">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Release"/>
        </Style>
        <Style Selector="Button.filmstrip-tile:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.92"/>
        </Style>
        <Style Selector="Button.popup-lite">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="#D6DCE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#1F2430"/>
        </Style>
        <Style Selector="Button.popup-lite:pointerover">
            <Setter Property="Background" Value="#EDF1F6"/>
        </Style>
        <Style Selector="Button.popup-danger">
            <Setter Property="Background" Value="#FFEDEE"/>
            <Setter Property="BorderBrush" Value="#F1C4C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#A1262D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.popup-danger:pointerover">
            <Setter Property="Background" Value="#FFE3E5"/>
        </Style>
    </Window.Styles>

    <!-- 边缘 6px 命中区 + 中心卡片；最大化时边缘改为 0，避免透明缝露出桌面 -->
    <Grid x:Name="OuterChromeGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="ResizeNw" Grid.Row="0" Grid.Column="0"
                Background="Transparent" Cursor="TopLeftCorner" PointerPressed="ResizeNw_OnPointerPressed"/>
        <Border x:Name="ResizeN" Grid.Row="0" Grid.Column="1"
                Background="Transparent" Cursor="SizeNorthSouth" PointerPressed="ResizeN_OnPointerPressed"/>
        <Border x:Name="ResizeNe" Grid.Row="0" Grid.Column="2"
                Background="Transparent" Cursor="TopRightCorner" PointerPressed="ResizeNe_OnPointerPressed"/>

        <Border x:Name="ResizeW" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2"
                Background="Transparent" Cursor="SizeWestEast" PointerPressed="ResizeW_OnPointerPressed"/>
        <Border x:Name="ResizeE" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                Background="Transparent" Cursor="SizeWestEast" PointerPressed="ResizeE_OnPointerPressed"/>

        <Border x:Name="ResizeSw" Grid.Row="3" Grid.Column="0"
                Background="Transparent" Cursor="BottomLeftCorner" PointerPressed="ResizeSw_OnPointerPressed"/>
        <Border x:Name="ResizeS" Grid.Row="3" Grid.Column="1"
                Background="Transparent" Cursor="SizeNorthSouth" PointerPressed="ResizeS_OnPointerPressed"/>
        <Border x:Name="ResizeSe" Grid.Row="3" Grid.Column="2"
                Background="Transparent" Cursor="BottomRightCorner" PointerPressed="ResizeSe_OnPointerPressed"/>

        <Border x:Name="CardRoot"
                Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                CornerRadius="14"
                ClipToBounds="True"
                Background="#F6F7FA"
                BorderBrush="#D9DEE8"
                BorderThickness="1"
                BoxShadow="0 12 40 0 #28000000">
            <Grid RowDefinitions="Auto,Auto,*"
                  Grid.IsSharedSizeScope="True">
                <!-- 标题栏：拖拽移动；图标与「页面标题」同排；作者信息仅悬停页面标题时显示 -->
                <Border x:Name="TitleBarHost"
                        Grid.Row="0"
                        MinHeight="44"
                        Background="#EEF0F5"
                        BorderBrush="#D9DEE8"
                        BorderThickness="0,0,0,1"
                        Padding="12,0,4,0"
                        PointerPressed="TitleBar_OnPointerPressed">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <Image Grid.Column="0"
                               Width="22" Height="22"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Source="avares://SonySmartControl/Assets/cheems.ico"
                               IsHitTestVisible="False"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <TextBlock x:Name="AppTitleText"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2430"
                                       Text="索尼实时视窗"
                                       Cursor="Help"
                                       IsHitTestVisible="True">
                                <ToolTip.Tip>
                                    <StackPanel MinWidth="200" Spacing="4">
                                        <TextBlock Text="作者：萤灬虫"/>
                                        <TextBlock Text="B站ID：43096314"/>
                                    </StackPanel>
                                </ToolTip.Tip>
                            </TextBlock>
                            <Button x:Name="CameraConnectionBadgeButton"
                                    MinWidth="56"
                                    Height="24"
                                    Padding="10,0"
                                    CornerRadius="12"
                                    Background="{Binding CameraConnectionBadgeBackground}"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding IsSessionActive}"
                                    Focusable="False"
                                    Classes="chrome-text"
                                    Click="CameraConnectionBadgeButton_OnClick"
                                    ToolTip.Tip="{Binding CameraConnectionTooltip}">
                                <TextBlock Text="{Binding CameraConnectionBadgeText}"
                                           Foreground="{Binding CameraConnectionBadgeForeground}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="12,0,0,0"
                                   Foreground="#5B6575"
                                   FontSize="12"
                                   Text="{Binding TransportSpeedText}"
                                   ToolTip.Tip="相机会话吞吐估算（上传/下载字节每秒），USB 与网口均按与相机相关调用统计。"/>
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <Button x:Name="ChromeMinimize"
                                    Classes="chrome-caption-btn"
                                    Click="ChromeMinimize_OnClick"
                                    ToolTip.Tip="最小化">
                                <Path Width="10" Height="1" Stretch="None"
                                      Stroke="#5C6370" StrokeThickness="1.25"
                                      Data="M 0 0 L 10 0"/>
                            </Button>
                            <Button x:Name="ChromeMaximize"
                                    Classes="chrome-caption-btn"
                                    Click="ChromeMaximize_OnClick"
                                    ToolTip.Tip="最大化">
                                <Panel>
                                    <Path x:Name="MaximizeGlyph"
                                          Width="12" Height="12" Stretch="Uniform"
                                          Stroke="#5C6370" StrokeThickness="1.15"
                                          Fill="Transparent"
                                          Data="M 2 2 L 10 2 L 10 10 L 2 10 Z"/>
                                    <Path x:Name="RestoreGlyph"
                                          IsVisible="False"
                                          Width="12" Height="12" Stretch="Uniform"
                                          Stroke="#5C6370" StrokeThickness="1.1"
                                          Fill="Transparent"
                                          Data="M 4 2 L 10 2 L 10 7 L 4 7 Z M 2 5 L 8 5 L 8 10 L 2 10 Z"/>
                                </Panel>
                            </Button>
                            <Button x:Name="ChromeClose"
                                    Classes="chrome-caption-close"
                                    Click="ChromeClose_OnClick"
                                    ToolTip.Tip="关闭">
                                <TextBlock Text="✕"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

            <!-- 已连接后点击徽标弹出的浮窗：格式化 SD 卡等 -->
            <Popup x:Name="ConnectedActionsPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding #CameraConnectionBadgeButton}"
                   IsOpen="False"
                   IsLightDismissEnabled="True">
                <Border Padding="12"
                        CornerRadius="12"
                        Background="#FFFFFF"
                        BorderBrush="#D9DEE8"
                        BorderThickness="1"
                        BoxShadow="0 10 30 0 #22000000">
                    <StackPanel Spacing="10" MinWidth="280">
                        <TextBlock Text="相机操作"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2430"/>
                        <Border Padding="10"
                                CornerRadius="8"
                                BorderBrush="#E5EAF0"
                                BorderThickness="1"
                                Background="#FAFBFD">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               Text="屏幕开关"
                                               ToolTip.Tip="关闭后机身背屏熄灭；开启后恢复显示。"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  OnContent="开"
                                                  OffContent="关"
                                                  IsChecked="{Binding CameraScreenPowerOn, Mode=TwoWay}"
                                                  IsEnabled="{Binding CameraScreenPowerEnabled}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               Text="LiveView 取流"
                                               ToolTip.Tip="关闭后停止 CMOS 实时取流；拍照控制仍可用。"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  OnContent="开"
                                                  OffContent="关"
                                                  IsChecked="{Binding LiveViewEnabled, Mode=TwoWay}"
                                                  IsEnabled="{Binding LiveViewEnabledControlEnabled}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- SD 卡容量/使用量进度条：用于格式化 SD 卡前的状态预览 -->
                        <Border Padding="10"
                                CornerRadius="8"
                                BorderBrush="#E5EAF0"
                                BorderThickness="1"
                                Background="#FFFFFF">
                            <StackPanel Spacing="10">
                                <TextBlock Text="SD 卡容量与使用量"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2430"/>

                                <StackPanel Spacing="8">
                                    <Border IsVisible="{Binding SdCardSlot1HasCard}"
                                            Padding="10"
                                            CornerRadius="8"
                                            BorderBrush="#E5EAF0"
                                            BorderThickness="1"
                                            Background="#FAFBFD">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="SLOT1"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1F2430"/>
                                            <TextBlock Text="{Binding SdCardSlot1SummaryText}"
                                                       FontSize="12"
                                                       Foreground="#6B7280"/>
                                            <ProgressBar Value="{Binding SdCardSlot1UsagePercent}"
                                                         Maximum="100"
                                                         Height="8"
                                                         Background="#E8EBF2"
                                                         Foreground="{Binding SdCardSlot1ProgressBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border IsVisible="{Binding SdCardSlot2HasCard}"
                                            Padding="10"
                                            CornerRadius="8"
                                            BorderBrush="#E5EAF0"
                                            BorderThickness="1"
                                            Background="#FAFBFD">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="SLOT2"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1F2430"/>
                                            <TextBlock Text="{Binding SdCardSlot2SummaryText}"
                                                       FontSize="12"
                                                       Foreground="#6B7280"/>
                                            <ProgressBar Value="{Binding SdCardSlot2UsagePercent}"
                                                         Maximum="100"
                                                         Height="8"
                                                         Background="#E8EBF2"
                                                         Foreground="{Binding SdCardSlot2ProgressBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button Classes="popup-lite"
                                Content="格式化 SD 卡"
                                IsEnabled="{Binding IsSessionActive}"
                                Command="{Binding RequestFormatSdCardConfirmCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="12,8"
                                ToolTip.Tip="清空并初始化存储卡（可能需要数十秒，请勿在执行过程中断开）。"/>
                        <Border IsVisible="{Binding ShowFormatSdCardConfirm}"
                                Margin="0,4,0,0"
                                Padding="10"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#F1D7A8"
                                Background="#FFF9ED">
                            <StackPanel Spacing="8">
                                <TextBlock Text="风险提醒"
                                           FontWeight="SemiBold"
                                           Foreground="#9A6A00"/>
                                <TextBlock Text="格式化会清空 SD 卡内所有照片/视频，且通常不可恢复。请确认已完成备份，并确保相机电量充足。"
                                           TextWrapping="Wrap"
                                           Foreground="#5B4A21"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                    <Button Classes="popup-lite"
                                            Content="取消"
                                            Command="{Binding CancelFormatSdCardConfirmCommand}"/>
                                    <Button Classes="popup-danger"
                                            Content="确认格式化"
                                            Command="{Binding ConfirmFormatSdCardCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>

                <!-- 工具行：左侧连接/状态不占用右侧栏宽度；右上与侧栏列对齐：拍照/摄影切换 -->
                <Border Grid.Row="1" Padding="16,12,16,0" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="280"
                                              MinWidth="240"
                                              SharedSizeGroup="RightSidebarWidth"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Top">
                            <Button Classes="chrome-text"
                                    Content="连接"
                                    Command="{Binding ConnectCommand}"
                                    IsEnabled="{Binding IsConnectEnabled}"/>
                            <Button Classes="chrome-text"
                                    Content="断开"
                                    Command="{Binding DisconnectCommand}"
                                    IsEnabled="{Binding IsDisconnectEnabled}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="#4B5260"/>
                        </StackPanel>
                        <Border Grid.Column="2"
                                VerticalAlignment="Top"
                                CornerRadius="10"
                                Background="#E8EBF2"
                                Padding="3"
                                ClipToBounds="True">
                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="0"
                                        Margin="0,0,2,0"
                                        CornerRadius="8,3,3,8"
                                        Background="#D4E8FC"
                                        IsVisible="{Binding IsPhotoSidebarMode}"/>
                                <Border Grid.Column="1"
                                        Margin="2,0,0,0"
                                        CornerRadius="3,8,8,3"
                                        Background="#D4E8FC"
                                        IsVisible="{Binding IsVideoSidebarMode}"/>
                                <Grid Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*">
                                    <Button Grid.Column="0"
                                            Classes="chrome-text"
                                            Content="拍照"
                                            Command="{Binding SelectPhotoSidebarModeCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="10,8"
                                            Background="Transparent"
                                            BorderThickness="0"/>
                                    <Button Grid.Column="1"
                                            Classes="chrome-text"
                                            Content="摄影"
                                            Command="{Binding SelectVideoSidebarModeCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="10,8"
                                            Background="Transparent"
                                            BorderThickness="0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"
                                              MinWidth="420"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="280"
                                              MinWidth="240"
                                              SharedSizeGroup="RightSidebarWidth"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" MinHeight="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4*"
                                               MinHeight="220"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="1.2*"
                                               MinHeight="110"/>
                            </Grid.RowDefinitions>
                            <!-- 预览框与底部胶片条分离：预览仅含实时画面与叠加层 -->
                                <Border x:Name="PreviewBorder"
                                        Grid.Row="0"
                                        Background="Transparent"
                                        BorderBrush="#D0D5DE" BorderThickness="1" CornerRadius="12" ClipToBounds="True"
                                        SizeChanged="PreviewBorder_OnSizeChanged">
                                    <Grid>
                                        <Border Background="Transparent"
                                                ClipToBounds="True"
                                                IsVisible="{Binding IsLivePreviewVisible}"
                                                PointerPressed="PreviewBorder_OnPointerPressed"
                                                PointerReleased="PreviewBorder_OnPointerReleased"
                                                PointerCaptureLost="PreviewBorder_OnPointerCaptureLost"
                                                Cursor="Hand"
                                                ToolTip.Tip="在预览上按下并按住：选对焦点并半按对焦；松开以释放。机身对焦框右上角可取消遥控触摸区域。">
                                            <Grid Background="Transparent" ClipToBounds="True">
                                                <Image Source="{Binding PreviewImage}" Stretch="Uniform" IsHitTestVisible="False"/>
                                                <controls:CompositionGuideOverlay ModeIndex="{Binding GuideOverlayIndex}"
                                                                                  SourceImage="{Binding PreviewImage}"
                                                                                  IsVisible="{Binding IsGuideOverlayVisible}"/>
                                                <controls:LuminanceHistogramOverlay SourceImage="{Binding PreviewImage}"
                                                                                    Bins="{Binding LuminanceHistogramBins}"
                                                                                    IsVisible="{Binding IsHistogramOverlayVisible}"/>
                                                <controls:AfFocusFramesOverlay SourceImage="{Binding PreviewImage}"
                                                                               Frames="{Binding SdkAfFocusFrames}"
                                                                               IsVisible="{Binding IsSdkAfFramesOverlayVisible}"/>
                                                <Button HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="{Binding FocusReticleCloseMargin}"
                                                        Width="22" Height="22"
                                                        Padding="0"
                                                        Background="#DC202020"
                                                        BorderThickness="0"
                                                        CornerRadius="11"
                                                        Cursor="Hand"
                                                        IsVisible="{Binding IsFocusReticleCloseButtonVisible}"
                                                        Command="{Binding DismissPreviewTouchFocusCommand}"
                                                        ToolTip.Tip="取消触摸对焦点，机身恢复自动对焦区域">
                                                    <TextBlock Text="×"
                                                               FontSize="15"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <controls:PhotoPanZoomViewer IsVisible="{Binding IsStaticReviewVisible}"
                                                                     Source="{Binding StaticReviewImage}"/>
                                    </Grid>
                                </Border>

                                <GridSplitter Grid.Row="1"
                                              Height="6"
                                              Margin="16,0,16,0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              ResizeDirection="Rows"
                                              ResizeBehavior="PreviousAndNext"
                                              Cursor="SizeNorthSouth"
                                              Background="#01000000"
                                              BorderThickness="0"/>

                                <Border x:Name="RecentFilmstripBar"
                                        Grid.Row="2"
                                        CornerRadius="12"
                                        Background="#FFFFFF"
                                        BorderBrush="#D9DEE8"
                                        BorderThickness="1"
                                        Padding="12,10"
                                        ClipToBounds="True"
                                        BoxShadow="0 2 8 0 #12000000">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0"
                                                    Width="126"
                                                    VerticalAlignment="Center">
                                            <Panel Height="96">
                                                <Border CornerRadius="8"
                                                        Background="#EEF1F6"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"/>
                                                <Border CornerRadius="8"
                                                        IsVisible="{Binding IsViewingLiveMonitor}"
                                                        Background="#D4E8FC"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"/>
                                                <Button Classes="filmstrip-tile"
                                                        Height="96"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Focusable="False"
                                                        Command="{Binding ShowLiveMonitorCommand}"
                                                        ToolTip.Tip="返回实时取景">
                                                    <TextBlock Text="实时"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1E3A5F"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </Panel>
                                        </StackPanel>

                                        <controls:FilmstripPhotosHost x:Name="FilmstripPhotos"
                                                                      Grid.Column="1"
                                                                      SizeChanged="FilmstripPhotos_OnSizeChanged"
                                                                      ItemsSource="{Binding RecentPhotos}"
                                                                      SelectCommand="{Binding ShowRecentPhotoCommand}"
                                                                      DeleteCommand="{Binding DeletePreviewImageCommand}"/>
                                    </Grid>
                                </Border>
                        </Grid>

                        <GridSplitter Grid.Column="1"
                                      Width="6"
                                      Margin="0,10,0,10"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ResizeDirection="Columns"
                                      ResizeBehavior="PreviousAndNext"
                                      Cursor="SizeWestEast"
                                      Background="#01000000"
                                      BorderThickness="0"/>

                        <Grid Grid.Column="2" MinHeight="0">
                                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" IsVisible="{Binding IsPhotoSidebarMode}">
                                <StackPanel Grid.Row="0" Spacing="8">
                                    <TextBlock FontWeight="SemiBold" Foreground="#1F2430" Text="遥控拍摄"/>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <Button Grid.Column="0"
                                                x:Name="FocusHoldButton"
                                                Classes="camera-focus"
                                                Content="对焦"
                                                IsEnabled="{Binding ShutterActionButtonsEnabled}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                ToolTip.Tip="可选：与在预览上按住相同（半按对焦，松开释放）。未在预览选点时则为普通半按。"/>
                                        <Button Grid.Column="1"
                                                x:Name="CaptureHoldButton"
                                                Classes="camera-capture"
                                                Content="拍照"
                                                IsEnabled="{Binding ShutterActionButtonsEnabled}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                ToolTip.Tip="单张/延时：按住半按对焦，松开释放快门一次。连拍模式：按住后半按对焦再全按连拍，保持按住可持续连拍，松手停止。保存路径与格式在侧栏「保存设置」中修改后立即生效。"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
                                    <Button Classes="sidebar-icon-tool"
                                            Command="{Binding ExpandAllSectionsCommand}"
                                            ToolTip.Tip="全部展开">
                                        <Path Width="18" Height="18" Stretch="Uniform"
                                              Stroke="#666666" StrokeThickness="1.65"
                                              Data="M 2 3 L 10 11 L 18 3 M 2 9 L 10 17 L 18 9"/>
                                    </Button>
                                    <Button Classes="sidebar-icon-tool"
                                            Command="{Binding CollapseAllSectionsCommand}"
                                            ToolTip.Tip="全部收起">
                                        <Path Width="18" Height="18" Stretch="Uniform"
                                              Stroke="#666666" StrokeThickness="1.65"
                                              Data="M 2 15 L 10 7 L 18 15 M 2 9 L 10 1 L 18 9"/>
                                    </Button>
                                </StackPanel>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" ClipToBounds="False">
                                    <StackPanel Spacing="10">
                                        <Expander IsExpanded="{Binding SaveSectionExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch">
                                            <Expander.Header>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="保存设置"
                                                           VerticalAlignment="Center"/>
                                            </Expander.Header>
                                            <StackPanel Spacing="10" Margin="0,4,0,0">
                                                <TextBlock Text="保存目录"/>
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                                    <TextBox Grid.Column="0" Text="{Binding SaveDirectory}" Watermark="文件夹路径"/>
                                                    <Button Grid.Column="1"
                                                            Classes="chrome-text"
                                                            Content="浏览…"
                                                            Command="{Binding BrowseSaveFolderCommand}"
                                                            Padding="12,6"/>
                                                    <Button Grid.Column="2"
                                                            Classes="chrome-text"
                                                            Content="打开"
                                                            Command="{Binding OpenSaveFolderCommand}"
                                                            Padding="12,6"
                                                            ToolTip.Tip="在文件资源管理器中打开此文件夹"/>
                                                </Grid>

                                                <TextBlock Text="文件名前缀"/>
                                                <TextBox Text="{Binding FileNamePrefix}" Watermark="例如 DSC"/>

                                                <TextBlock Text="保存格式"/>
                                                <ComboBox SelectedIndex="{Binding CaptureFormatIndex}">
                                                    <ComboBoxItem Content="JPEG"/>
                                                    <ComboBoxItem Content="RAW"/>
                                                    <ComboBoxItem Content="RAW + JPEG"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Expander>

                                        <Border IsVisible="{Binding ShootingPanelVisible}"
                                                Opacity="{Binding ShootingPanelOpacity}"
                                                Padding="0,4,0,0">
                                            <StackPanel Spacing="10">
                                                <Expander IsExpanded="{Binding ExposureSectionExpanded, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch">
                                                    <Expander.Header>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="拍照设置"
                                                                   VerticalAlignment="Center"/>
                                                    </Expander.Header>
                                                    <StackPanel Spacing="8" Margin="0,4,0,0">
                                                        <TextBlock Text="对焦模式"
                                                                   ToolTip.Tip="若下拉为灰色：机身须允许从电脑改写（Writable）；AF/MF 开关在镜头或菜单上、部分模式会锁定对焦。"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding FocusModeChoices}"
                                                                                   SelectedIndex="{Binding SelectedFocusModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding FocusModeEnabled}"/>

                                                        <TextBlock Text="拍摄方式"
                                                                   ToolTip.Tip="单张 / 连拍 / 延时自拍，对应机身驱动模式（CrDeviceProperty_DriveMode）。连拍与延时下可选具体速度或秒数。"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding DriveModeCategoryLabels}"
                                                                  SelectedIndex="{Binding SelectedDriveCategoryIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding DriveModeCategoryEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged"/>
                                                        <TextBlock Text="{Binding DriveModeSubLabel}"
                                                                   IsVisible="{Binding DriveModeSubRowVisible}"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding DriveModeSubChoices}"
                                                                  SelectedIndex="{Binding SelectedDriveSubIndex, Mode=TwoWay}"
                                                                  IsVisible="{Binding DriveModeSubRowVisible}"
                                                                  IsEnabled="{Binding DriveModeCategoryEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <TextBlock Text="{Binding DriveModeOtherHint}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="11"
                                                                   Opacity="0.85"
                                                                   Foreground="#666666"
                                                                   IsVisible="{Binding HasDriveModeOtherHint}"/>

                                                        <TextBlock Text="曝光模式（P/A/S/M 等）"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding ExposureModeChoices}"
                                                                                   SelectedIndex="{Binding SelectedExposureModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding ExposureModeEnabled}"/>

                                                        <TextBlock Text="光圈"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding ApertureChoices}"
                                                                                   SelectedIndex="{Binding SelectedApertureIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding ApertureEnabled}"
                                                                                   WheelAdjustEnabled="True"/>

                                                        <TextBlock Text="快门类型"
                                                                   ToolTip.Tip="自动 / 机械快门 / 电子快门（CrDeviceProperty_ShutterType）。不支持或不可调时机身为灰色。"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding ShutterTypeChoices}"
                                                                  SelectedIndex="{Binding SelectedShutterTypeIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding ShutterTypeEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBlock Text="快门速度"/>
                                                        <ComboBox x:Name="ShutterSpeedCombo"
                                                                  MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding ShutterChoices}"
                                                                  SelectedIndex="{Binding SelectedShutterIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding ShutterEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBlock Text="ISO"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding IsoChoices}"
                                                                                   SelectedIndex="{Binding SelectedIsoIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding IsoEnabled}"
                                                                                   WheelAdjustEnabled="True"/>

                                                        <TextBlock Text="曝光补偿"
                                                                   ToolTip.Tip="与机身曝光补偿（±EV）一致；数值为 SDK 的「EV×1000」。下拉选择；或在本框悬停约 0.75s 后用滚轮微调（与光圈/快门/ISO 相同）。"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding ExposureBiasChoices}"
                                                                                   SelectedIndex="{Binding SelectedExposureBiasIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding ExposureBiasEnabled}"
                                                                                   InvertWheel="True"
                                                                                   WheelAdjustEnabled="True"/>
                                                        <TextBlock Text="{Binding ExposureCompensationHint}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="11"
                                                                   Opacity="0.85"
                                                                   Foreground="#B06020"
                                                                   IsVisible="{Binding HasExposureCompensationHint}"/>
                                                    </StackPanel>
                                                </Expander>

                                                <Expander IsExpanded="{Binding FlashSectionExpanded, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch">
                                                    <Expander.Header>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="闪光灯设置"
                                                                   VerticalAlignment="Center"/>
                                                    </Expander.Header>
                                                    <StackPanel Spacing="8" Margin="0,4,0,0">
                                                        <TextBlock Text="闪光模式"
                                                                   ToolTip.Tip="自动、关闭、强制闪光、慢速/后帘同步等；实际可选项由机身返回。"/>
                                                        <ComboBox MinHeight="32"
                                                                  HorizontalAlignment="Stretch"
                                                                  ItemsSource="{Binding FlashModeChoices}"
                                                                  SelectedIndex="{Binding SelectedFlashModeIndex, Mode=TwoWay}"
                                                                  IsEnabled="{Binding FlashModeEnabled}"
                                                                  PointerWheelChanged="ShutterCombo_OnPointerWheelChanged">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="interop:ShootingChoiceItem">
                                                                    <TextBlock Text="{Binding Display}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBlock Text="闪光补偿"/>
                                                        <controls:WheelPickerCombo ItemsSource="{Binding FlashCompensationChoices}"
                                                                                   SelectedIndex="{Binding SelectedFlashCompensationIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                   IsEnabled="{Binding FlashCompensationEnabled}"
                                                                                   InvertWheel="True"
                                                                                   WheelAdjustEnabled="True"/>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </Border>

                                        <Expander IsExpanded="{Binding AuxDisplaySectionExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch">
                                            <Expander.Header>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="辅助显示"
                                                           VerticalAlignment="Center"/>
                                            </Expander.Header>
                                            <StackPanel Spacing="8" Margin="0,4,0,0">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Text="直方图"
                                                               ToolTip.Tip="关闭后不显示右上角亮度直方图。"/>
                                                    <ToggleSwitch Grid.Column="1"
                                                                  VerticalAlignment="Center"
                                                                  OnContent="开"
                                                                  OffContent="关"
                                                                  IsChecked="{Binding ShowHistogram, Mode=TwoWay}"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Text="辅助线"
                                                               ToolTip.Tip="在预览画面有效区域内叠加构图参考线。"/>
                                                    <controls:WheelPickerCombo Grid.Column="1"
                                                                               MinWidth="168"
                                                                               ItemsSource="{Binding GuideOverlayChoices}"
                                                                               SelectedIndex="{Binding GuideOverlayIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander>

                                        <Expander IsExpanded="{Binding TimelapseSectionExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch">
                                            <Expander.Header>
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="延时摄影"
                                                           VerticalAlignment="Center"/>
                                            </Expander.Header>
                                            <StackPanel Spacing="8" Margin="0,4,0,0">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Text="间隔（秒）"
                                                               ToolTip.Tip="C# 定时器实现；最低间隔 2 秒，实际周期会因拍照与传输耗时而略长。"/>
                                                    <TextBox Grid.Column="1"
                                                             MinWidth="80"
                                                             Text="{Binding TimelapseIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Text="总张数（0=无限制）"
                                                               ToolTip.Tip="如果填写 0，将持续拍摄直到你点“停止”。"/>
                                                    <TextBox Grid.Column="1"
                                                             MinWidth="80"
                                                             Text="{Binding TimelapseTargetFrames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <TextBlock Text="{Binding TimelapseProgressText}"
                                                           Foreground="#6B7280"/>

                                                <TextBlock Text="保存目录"
                                                           ToolTip.Tip="延时摄影单独保存到此文件夹（与遥控拍摄目录独立）。"/>
                                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding TimelapseSaveDirectory}"
                                                             Watermark="延时摄影文件夹路径"/>
                                                    <Button Grid.Column="1"
                                                            Classes="chrome-text"
                                                            Content="浏览…"
                                                            Command="{Binding BrowseTimelapseSaveFolderCommand}"
                                                            Padding="12,6"/>
                                                    <Button Grid.Column="2"
                                                            Classes="chrome-text"
                                                            Content="打开"
                                                            Command="{Binding OpenTimelapseSaveFolderCommand}"
                                                            Padding="12,6"
                                                            ToolTip.Tip="在文件资源管理器中打开此文件夹"/>
                                                </Grid>

                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Button Classes="chrome-text"
                                                            Content="开始"
                                                            Command="{Binding StartTimelapseCommand}"
                                                            Padding="14,6"/>
                                                    <Button Classes="chrome-text"
                                                            Content="暂停"
                                                            Command="{Binding PauseTimelapseCommand}"
                                                            Padding="14,6"/>
                                                    <Button Classes="chrome-text"
                                                            Content="继续"
                                                            Command="{Binding ContinueTimelapseCommand}"
                                                            Padding="14,6"/>
                                                    <Button Classes="chrome-text"
                                                            Content="停止"
                                                            Command="{Binding StopTimelapseCommand}"
                                                            Padding="14,6"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </ScrollViewer>
                                </Grid>
                                <Border CornerRadius="12"
                                        Background="#FFFFFF"
                                        BorderBrush="#D9DEE8"
                                        BorderThickness="1"
                                        Padding="24"
                                        VerticalAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        IsVisible="{Binding IsVideoSidebarMode}">
                                    <TextBlock Text="开发中"
                                               FontSize="15"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SonySmartControl.ViewModels"
        xmlns:models="using:SonySmartControl.Models"
        xmlns:helpers="using:SonySmartControl.Helpers"
        x:Class="SonySmartControl.Views.DeviceSearchWindow"
        x:DataType="vm:DeviceSearchViewModel"
        x:Name="Root"
        Title="设备搜索"
        Icon="{x:Static helpers:AppIconUris.WindowIcon}"
        Width="640"
        Height="520"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        CanResize="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="False"
        Loaded="DeviceSearchWindow_OnLoaded">

    <Grid x:Name="OuterChromeGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="ResizeNw" Grid.Row="0" Grid.Column="0"
                Background="Transparent" Cursor="TopLeftCorner" PointerPressed="ResizeNw_OnPointerPressed"/>
        <Border x:Name="ResizeN" Grid.Row="0" Grid.Column="1"
                Background="Transparent" Cursor="SizeNorthSouth" PointerPressed="ResizeN_OnPointerPressed"/>
        <Border x:Name="ResizeNe" Grid.Row="0" Grid.Column="2"
                Background="Transparent" Cursor="TopRightCorner" PointerPressed="ResizeNe_OnPointerPressed"/>

        <Border x:Name="ResizeW" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2"
                Background="Transparent" Cursor="SizeWestEast" PointerPressed="ResizeW_OnPointerPressed"/>
        <Border x:Name="ResizeE" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                Background="Transparent" Cursor="SizeWestEast" PointerPressed="ResizeE_OnPointerPressed"/>

        <Border x:Name="ResizeSw" Grid.Row="3" Grid.Column="0"
                Background="Transparent" Cursor="BottomLeftCorner" PointerPressed="ResizeSw_OnPointerPressed"/>
        <Border x:Name="ResizeS" Grid.Row="3" Grid.Column="1"
                Background="Transparent" Cursor="SizeNorthSouth" PointerPressed="ResizeS_OnPointerPressed"/>
        <Border x:Name="ResizeSe" Grid.Row="3" Grid.Column="2"
                Background="Transparent" Cursor="BottomRightCorner" PointerPressed="ResizeSe_OnPointerPressed"/>

        <Border x:Name="CardRoot"
                Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                CornerRadius="14"
                ClipToBounds="True"
                Background="#F6F7FA"
                BorderBrush="#D9DEE8"
                BorderThickness="1"
                BoxShadow="0 12 40 0 #28000000">
            <Grid RowDefinitions="Auto,*">
                <Border x:Name="TitleBarHost"
                        Grid.Row="0"
                        MinHeight="44"
                        Margin="1,1,1,0"
                        CornerRadius="13,13,0,0"
                        Background="#EEF0F5"
                        BorderBrush="#D9DEE8"
                        BorderThickness="0,0,0,1"
                        Padding="12,0,4,0"
                        PointerPressed="TitleBar_OnPointerPressed">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <Image Width="22"
                                   Height="22"
                                   VerticalAlignment="Center"
                                   Source="avares://SonySmartControl/Assets/cheems.ico"/>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2430"
                                       Text="设备搜索"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <Button x:Name="ChromeMinimize"
                                    Classes="chrome-caption-btn"
                                    Click="ChromeMinimize_OnClick"
                                    ToolTip.Tip="最小化">
                                <TextBlock Text="&#xE65A;"
                                           FontFamily="avares://SonySmartControl/Assets/Fonts/iconfont.ttf#CheemsFont"
                                           FontSize="14"
                                           Foreground="#5C6370"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="ChromeMaximize"
                                    Classes="chrome-caption-btn"
                                    Click="ChromeMaximize_OnClick"
                                    ToolTip.Tip="最大化">
                                <Panel>
                                    <TextBlock x:Name="MaximizeGlyph"
                                               Text="&#xE6F7;"
                                               FontFamily="avares://SonySmartControl/Assets/Fonts/iconfont.ttf#CheemsFont"
                                               FontSize="14"
                                               Foreground="#5C6370"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RestoreGlyph"
                                               IsVisible="False"
                                               Text="&#xE66E;"
                                               FontFamily="avares://SonySmartControl/Assets/Fonts/iconfont.ttf#CheemsFont"
                                               FontSize="14"
                                               Foreground="#5C6370"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Panel>
                            </Button>
                            <Button x:Name="ChromeClose"
                                    Classes="chrome-caption-close"
                                    Click="ChromeClose_OnClick"
                                    Margin="2,0,6,0"
                                    Background="#EA4235"
                                    CornerRadius="8"
                                    ToolTip.Tip="关闭">
                                <TextBlock Text="&#xE64D;"
                                           FontFamily="avares://SonySmartControl/Assets/Fonts/iconfont.ttf#CheemsFont"
                                           FontSize="14"
                                           Foreground="#FFFFFF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      MinHeight="0">
                    <Grid Margin="16,12,16,16"
                          RowDefinitions="Auto,Auto,*,Auto">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusHint}"/>
                            <Button Grid.Column="1"
                                    Classes="chrome-text"
                                    Padding="12,6"
                                    Command="{Binding RefreshCommand}"
                                    Content="重新搜索"
                                    IsEnabled="{Binding CanRefresh}"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                CornerRadius="10,10,0,0"
                                BorderBrush="#E5EAF0"
                                BorderThickness="1,1,1,0"
                                Background="#EBEEF5"
                                Padding="10,8">
                            <Grid ColumnDefinitions="44,*,96,200">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C6370"
                                           Text="序号"/>
                                <TextBlock Grid.Column="1"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C6370"
                                           Text="型号"/>
                                <TextBlock Grid.Column="2"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C6370"
                                           Text="连接"/>
                                <TextBlock Grid.Column="3"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#5C6370"
                                           Text="设备标识"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                CornerRadius="0,0,10,10"
                                BorderBrush="#E5EAF0"
                                BorderThickness="1"
                                Background="#FFFFFF"
                                Padding="0">
                            <Grid>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#9CA3AF"
                                           IsVisible="{Binding IsEmpty}"
                                           Text="未发现设备"/>
                                <ListBox ItemsSource="{Binding Devices}"
                                         SelectedItem="{Binding SelectedDevice}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.Styles>
                                        <Style Selector="ListBoxItem">
                                            <Setter Property="Padding" Value="10,8"/>
                                        </Style>
                                    </ListBox.Styles>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:DiscoveredCameraDevice">
                                            <Grid ColumnDefinitions="44,*,96,200"
                                                  ColumnSpacing="8">
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="13"
                                                           Foreground="#6B7280"
                                                           Text="{Binding OrdinalLabel}"/>
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           FontSize="13"
                                                           Foreground="#2B303B"
                                                           Text="{Binding ModelName}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="#4B5563"
                                                           Text="{Binding ConnectionTypeText}"/>
                                                <TextBlock Grid.Column="3"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="#6B7280"
                                                           Text="{Binding EndpointText}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="3"
                                    Margin="0,12,0,0"
                                    Spacing="10">
                            <TextBlock FontSize="12"
                                       Foreground="#B91C1C"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding ShowDiscoveryError}"
                                       Text="{Binding ErrorMessage}"/>
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                <Button Classes="chrome-text"
                                        Padding="16,8"
                                        Command="{Binding ConnectToSelectedCommand}"
                                        Content="连接至此设备"
                                        IsEnabled="{Binding ConnectButtonEnabled}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
